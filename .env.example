# =============================================================
# MiroFish-Offline — Battlematrix Configuration
# =============================================================
# bm-node1  : Intel Xeon W7-3465X + 4x Maxsun Arc B60 Dual 48G
#             = 8 Intel Arc chips x 24 GB = 192 GB total VRAM
#             vLLM (Intel XPU) on port 8000
# bm-control: AMD Ryzen 5 7600X + RTX 3060
#             Ollama (nomic-embed-text) + Neo4j on this host
# =============================================================
# Copy to .env and set real passwords.
# =============================================================

# ===== LLM — vLLM on bm-node1 (Intel XPU, TP=8) =====
# Model options (choose one):
#   qwen3-32b          — best quality, fits in 192 GB with TP=8
#   Qwen/Qwen3.5-35B-A3B — MoE, slightly faster, same VRAM footprint
LLM_API_KEY=EMPTY
LLM_BASE_URL=http://bm-node1:8000/v1
LLM_MODEL_NAME=qwen3-32b
# LLM_MODEL_NAME=Qwen/Qwen3.5-35B-A3B

# Boost config — used by Reddit platform in parallel simulations
# (same endpoint, vLLM handles concurrent requests natively)
LLM_BOOST_API_KEY=EMPTY
LLM_BOOST_BASE_URL=http://bm-node1:8000/v1
LLM_BOOST_MODEL_NAME=qwen3-32b

# ===== Embeddings — Ollama on bm-control =====
# nomic-embed-text stays on bm-control (RTX 3060, low VRAM overhead)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://bm-control:11434

# ===== Neo4j — on bm-control =====
NEO4J_URI=bolt://bm-control:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_IN_DOT_ENV

# ===== OASIS / CAMEL-AI — points to same vLLM =====
OPENAI_API_KEY=EMPTY
OPENAI_API_BASE_URL=http://bm-node1:8000/v1

# =============================================================
# HOW TO START vLLM on bm-node1 (Intel XPU, TP=8):
#
#   ZE_AFFINITY_MASK=0,1,2,3,4,5,6,7 \
#   vllm serve qwen3-32b \
#     --tensor-parallel-size 8 \
#     --max-model-len 8192 \
#     --gpu-memory-utilization 0.90 \
#     --device xpu \
#     --port 8000
#
# Or for Qwen3.5-35B-A3B (MoE):
#   ZE_AFFINITY_MASK=0,1,2,3,4,5,6,7 \
#   vllm serve Qwen/Qwen3.5-35B-A3B \
#     --tensor-parallel-size 8 \
#     --max-model-len 8192 \
#     --gpu-memory-utilization 0.90 \
#     --device xpu \
#     --port 8000
# =============================================================

# ===== Docker-mode overrides (when ALL services run in Docker) =====
# Uncomment when backend container talks to services by container name:
# LLM_BASE_URL=http://bm-node1:8000/v1
# NEO4J_URI=bolt://neo4j:7687
# EMBEDDING_BASE_URL=http://ollama:11434
# OPENAI_API_BASE_URL=http://bm-node1:8000/v1
