# =============================================================
# MiroFish-Offline — Battlematrix Docker Configuration
# =============================================================
# bm-node1  (192.168.10.2): Intel Xeon W7-3465X
#            4x Maxsun Arc B60 Dual 48G = 8 chips x 24 GB = 192 GB VRAM
#            vLLM (Intel XPU, TP=8) on port 8000
# bm-control (this host): AMD Ryzen 5 7600X + RTX 3060
#            Ollama (nomic-embed-text) on port 11434
#            Neo4j in Docker container (service name: neo4j)
#            Flask backend + Vue3 frontend in Docker
# =============================================================

# ===== API Keys =====
# vLLM does not validate keys, but Flask requires non-empty values
LLM_API_KEY=vllm
OPENAI_API_KEY=vllm

# ===== vLLM on bm-node1 (Intel XPU, TP=8) =====
LLM_BASE_URL=http://192.168.10.2:8000/v1
OPENAI_API_BASE_URL=http://192.168.10.2:8000/v1

# Model options (choose one):
#   qwen3:32b             — best quality, 192 GB VRAM, TP=8
#   Qwen/Qwen3.5-35B-A3B  — MoE, slightly faster inference
LLM_MODEL_NAME=qwen3:32b
# LLM_MODEL_NAME=Qwen/Qwen3.5-35B-A3B

# Boost LLM — Reddit platform in parallel simulations
# (same vLLM endpoint; server handles concurrent requests natively)
LLM_BOOST_API_KEY=vllm
LLM_BOOST_BASE_URL=http://192.168.10.2:8000/v1
LLM_BOOST_MODEL_NAME=qwen3:32b

# ===== Embeddings — Ollama on bm-control =====
# host.docker.internal resolves to the Docker host from inside a container
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://host.docker.internal:11434

# ===== Neo4j — Docker service on bm-control =====
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

# ===== Flask Backend =====
FLASK_ENV=development
FLASK_PORT=5001
FLASK_HOST=0.0.0.0

# =============================================================
# HOW TO START vLLM on bm-node1 (Intel XPU, TP=8):
#
#   ZE_AFFINITY_MASK=0,1,2,3,4,5,6,7 \
#   vllm serve qwen3:32b \
#     --tensor-parallel-size 8 \
#     --max-model-len 8192 \
#     --gpu-memory-utilization 0.90 \
#     --device xpu \
#     --port 8000
# =============================================================
